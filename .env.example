# Todo-OSINT Environment Variables

# AI Engine (optional - app works without it)
# Primary: Gemini (free, unlimited rate-limited, 1M context)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Fallback: Groq (free, Llama 3.3 70B, ultra-fast)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# App
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# Dev Pro User (auto-created on startup, never commit real values)
# DEV_USER_EMAIL=dev@yourapp.local
# DEV_USER_PASSWORD=change-me
